{
  "name": "brainstorming",
  "version": "0.1.1",
  "description": "A terminal group chat where Claude Code, Codex, Antigravity and Ollama collaborate in one shared conversation over your codebase.",
  "type": "module",
  "bin": {
    "brainstorming": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "demo": "tsx src/index.ts --demo",
    "start": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "tsup && cp ../../README.md ../../LICENSE ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "ink": "^6.0.0",
    "ollama": "^0.6.0",
    "react": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@brainstorming/adapters": "workspace:*",
    "@brainstorming/core": "workspace:*",
    "@brainstorming/tui": "workspace:*",
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0"
  },
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "tui",
    "claude",
    "codex",
    "ollama",
    "antigravity",
    "coding-agent",
    "cli"
  ],
  "author": "aliildan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aliildan/brainstorming.git"
  },
  "homepage": "https://github.com/aliildan/brainstorming#readme",
  "bugs": {
    "url": "https://github.com/aliildan/brainstorming/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
